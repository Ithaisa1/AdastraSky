# ============================================================
# ADASTRASKY - VARIABLES DE ENTORNO (FRONTEND)
# ============================================================
# Copia este archivo como .env y rellena los valores reales

# URL del Backend API
VITE_API_URL=https://aadastra-sky-backend.onrender.com

# URL del Microservicio de IA (opcional, para referencia)
VITE_AI_SERVICE_URL=http://localhost:8001

# Configuración de la Aplicación
VITE_APP_NAME=Adastra Sky
VITE_APP_VERSION=1.0.0

# Idioma por defecto (es, en, de)
VITE_DEFAULT_LANGUAGE=es

# Configuración del Mapa (opcional)
VITE_MAP_DEFAULT_LAT=28.2917
VITE_MAP_DEFAULT_LNG=-16.5111
VITE_MAP_DEFAULT_ZOOM=8

# Configuración de OpenWeather API (opcional, para uso directo)
VITE_OPENWEATHER_API_KEY=tu_clave_openweather_aqui

# Configuración de Analytics (opcional)
VITE_ENABLE_ANALYTICS=false
VITE_GA_TRACKING_ID=

# Modo de desarrollo
VITE_NODE_ENV=development
